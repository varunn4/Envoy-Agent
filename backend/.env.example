# ── Envoy Backend — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use default: ./data/db.sqlite
DB_PATH=

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Groq (optional fallback model) ────────────────────────────────────────────
GROQ_API_KEY=

# ─── Apollo.io ─────────────────────────────────────────────────────────────────
APOLLO_API_KEY=

# ─── Gmail / SMTP ──────────────────────────────────────────────────────────────
GMAIL_USER=you@gmail.com
# Path to the OAuth2 token file generated by scripts/get-gmail-token.js
GMAIL_TOKEN_PATH=./data/gmail-token.json

# ─── Google Chat (optional) ────────────────────────────────────────────────────
GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/...
GCHAT_SPACE_ID=
GCHAT_SERVICE_ACCOUNT_PATH=./data/service-account.json
